          {"id": "arch_s1_e_standard_width", "source": "arch_s1_n_standard", "relation": "requires_minimum", "target": "arch_var_width", "value": 30, "unit": "inch", "chunk_id": "arch_s1_c1"},
          {"id": "arch_s1_e_standard_depth", "source": "arch_s1_n_standard", "relation": "requires_minimum", "target": "arch_var_depth", "value": 60, "unit": "inch", "chunk_id": "arch_s1_c1"},
          {"id": "arch_s1_e_alt_width", "source": "arch_s1_n_alternate", "relation": "requires_minimum", "target": "arch_var_width", "value": 36, "unit": "inch", "chunk_id": "arch_s1_c2"},
          {"id": "arch_s1_e_alt_depth", "source": "arch_s1_n_alternate", "relation": "requires_minimum", "target": "arch_var_depth", "value": 36, "unit": "inch", "chunk_id": "arch_s1_c2"},
          {"id": "arch_s1_e_excludes", "source": "arch_s1_n_standard", "relation": "excludes", "target": "arch_s1_n_alternate", "chunk_id": "arch_s1_c3"}

        "shower_type": "roll_in",
        "template_policy": "standard_or_alternate"
      },
      "expected_behavior": {
        "required_relation_types": ["excludes"],
        "min_valid_structures": 2,
        "candidate_decisions": [
          {"id": "standard_30x60", "x": {"shower_width": 30, "shower_depth": 60}, "expected_valid": true},
          {"id": "alternate_36x36", "x": {"shower_width": 36, "shower_depth": 36}, "expected_valid": true},
          {"id": "mixed_35x48", "x": {"shower_width": 35, "shower_depth": 48}, "expected_valid": false}
        ]

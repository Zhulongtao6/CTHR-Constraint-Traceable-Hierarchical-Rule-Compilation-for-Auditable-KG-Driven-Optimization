        "source_chunks": [
          {"chunk_id": "arch_s1_c1", "document": "2010 ADA Standards for Accessible Design", "section": "608.2.2", "page": 165, "text": "A standard roll-in shower compartment provides a 30 inch by 60 inch minimum clearance."},
          {"chunk_id": "arch_s1_c2", "document": "2010 ADA Standards for Accessible Design", "section": "608.2.3", "page": 166, "text": "An alternate roll-in shower compartment provides a 36 inch by 36 inch minimum clearance."},
